# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=12345
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:secret@localhost:5432/advatech_lms?schema=public"

# ─── Redis (optional — queues degrade gracefully without it) ───────────────────
# REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# If unset in development, emails are logged to console instead of sent
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
SMTP_FROM=noreply@advatech.ac.ke

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
# If unset, file upload endpoints return 501
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=eu-west-1
# S3_BUCKET=advatech-tenants
# S3_URL_EXPIRES_SEC=3600

# ─── Multi-tenancy ─────────────────────────────────────────────────────────────
DEFAULT_INSTITUTION_ID=1
FRONTEND_URL=http://localhost:3000

# ─── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# ─── M-Pesa (Safaricom Daraja) ─────────────────────────────────────────────────
# https://developer.safaricom.co.ke
MPESA_ENV=sandbox
# MPESA_CONSUMER_KEY=your_key
# MPESA_CONSUMER_SECRET=your_secret
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=your_passkey
# MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/callback/mpesa

# ─── Zoom (optional — online class meeting creation) ───────────────────────────
# ZOOM_ACCOUNT_ID=your_account_id
# ZOOM_CLIENT_ID=your_client_id
# ZOOM_CLIENT_SECRET=your_client_secret
